def calculate_grade(cursor, student_id, crn, grade_type):
    """Calculates the average grade for a specific type, or the final grade."""
    if grade_type.lower() == 'final':
        # Calculate final grade based on weights in Courses table
        query = """
            SELECT 
                NVL(AVG(CASE WHEN gl.Grade_Type = 'hw' THEN gl.Grade_out_of_hund END), 0) * (c.Hw_Weight / 100) +
                NVL(AVG(CASE WHEN gl.Grade_Type = 'proj' THEN gl.Grade_out_of_hund END), 0) * (c.Proj_Weight / 100) +
                NVL(AVG(CASE WHEN gl.Grade_Type = 'test' THEN gl.Grade_out_of_hund END), 0) * (c.Tests_Weight / 100) +
                NVL(AVG(CASE WHEN gl.Grade_Type = 'Partic' THEN gl.Grade_out_of_hund END), 0) * (c.Participation_Weight / 100) +
                NVL(AVG(CASE WHEN gl.Grade_Type = 'other' THEN gl.Grade_out_of_hund END), 0) * (c.Other_Weight / 100) AS Final_Grade
            FROM Courses c
            LEFT JOIN Grade_List gl ON c.CRN = gl.CRN AND gl.Student_ID = :student_id
            WHERE c.CRN = :crn
            GROUP BY c.Hw_Weight, c.Proj_Weight, c.Tests_Weight, c.Participation_Weight, c.Other_Weight
        """
        cursor.execute(query, student_id=student_id, crn=crn)
    else:
        # Calculate average for a specific category
        query = """
            SELECT AVG(Grade_out_of_hund) 
            FROM Grade_List 
            WHERE Student_ID = :student_id AND CRN = :crn AND LOWER(Grade_Type) = LOWER(:grade_type)
        """
        cursor.execute(query, student_id=student_id, crn=crn, grade_type=grade_type)
        
    result = cursor.fetchone()
    if result and result[0] is not None:
        return round(result[0], 2)
    return "No grades found for this category."

def join_class(cursor, connection, student_id, crn):
    """Logic for a student to join a class."""
    # 1. Check if student has < 5 classes
    cursor.execute("SELECT CRN_1, CRN_2, CRN_3, CRN_4, CRN_5 FROM Students WHERE Student_ID = :sid", sid=student_id)
    student_record = cursor.fetchone()
    if not student_record:
        print("Student not found.")
        return

    empty_student_slot = None
    for i, enrolled_crn in enumerate(student_record):
        if enrolled_crn == crn:
            print("You are already enrolled in this class.")
            return
        if enrolled_crn is None and empty_student_slot is None:
            empty_student_slot = i + 1

    if empty_student_slot is None:
        print("You are already enrolled in the maximum of 5 classes.")
        return

    # 2. Check if class has < 5 students
    cursor.execute("SELECT Student_ID_1, Student_ID_2, Student_ID_3, Student_ID_4, Student_ID_5 FROM Courses WHERE CRN = :crn", crn=crn)
    course_record = cursor.fetchone()
    if not course_record:
        print("Course not found.")
        return

    empty_course_slot = None
    for i, enrolled_sid in enumerate(course_record):
        if enrolled_sid is None and empty_course_slot is None:
            empty_course_slot = i + 1

    if empty_course_slot is None:
        print("This class is already full (maximum 5 students).")
        return

    # 3. Update Students table
    update_student_sql = f"UPDATE Students SET CRN_{empty_student_slot} = :crn WHERE Student_ID = :sid"
    cursor.execute(update_student_sql, crn=crn, sid=student_id)

    # 4. Update Courses table
    update_course_sql = f"UPDATE Courses SET Student_ID_{empty_course_slot} = :sid WHERE CRN = :crn"
    cursor.execute(update_course_sql, sid=student_id, crn=crn)

    # 5. Insert into Grade_Nums
    cursor.execute("INSERT INTO Grade_Nums (CRN, Student_ID) VALUES (:crn, :sid)", crn=crn, sid=student_id)

    connection.commit()
    print(f"Successfully joined class {crn}!")

def add_grade(cursor, connection, crn, student_id, grade_name, grade_type, score):
    """Logic for a teacher to add a grade."""
    try:
        cursor.execute("""
            INSERT INTO Grade_List (CRN, Student_ID, Grade_Name, Grade_Type, Grade_out_of_hund)
            VALUES (:crn, :sid, :gname, :gtype, :score)
        """, crn=crn, sid=student_id, gname=grade_name, gtype=grade_type, score=score)
        connection.commit()
        print("Grade added successfully!")
    except oracledb.Error as e:
        print(f"Error adding grade: {e}")

def student_menu(cursor, connection):
    student_id = input("Enter your Student ID (e.g., S0001): ")
    while True:
        print("\n--- Student Menu ---")
        print("1. View Grades")
        print("2. Join a Class")
        print("3. Return to Main Menu")
        choice = input("Select an option: ")

        if choice == '1':
            crn = input("Enter the CRN of the class: ")
            print("Grade Types: hw, proj, test, Partic, other, final")
            g_type = input("Enter the grade type you want to view: ")
            grade = calculate_grade(cursor, student_id, crn, g_type)
            print(f"Your {g_type} grade for {crn} is: {grade}")
        elif choice == '2':
            crn = input("Enter the CRN of the class you want to join: ")
            join_class(cursor, connection, student_id, crn)
        elif choice == '3':
            break
        else:
            print("Invalid choice.")

def teacher_menu(cursor, connection):
    while True:
        print("\n--- Teacher Menu ---")
        print("1. View a Student's Grades")
        print("2. Add a Grade for a Student")
        print("3. Return to Main Menu")
        choice = input("Select an option: ")

        if choice == '1':
            student_id = input("Enter the Student ID: ")
            crn = input("Enter the CRN of the class: ")
            print("Grade Types: hw, proj, test, Partic, other, final")
            g_type = input("Enter the grade type you want to view: ")
            grade = calculate_grade(cursor, student_id, crn, g_type)
            print(f"Student {student_id}'s {g_type} grade for {crn} is: {grade}")
        elif choice == '2':
            crn = input("Enter the CRN of the class: ")
            student_id = input("Enter the Student ID: ")
            grade_name = input("Enter the Assignment Name (e.g., Homework 5): ")
            grade_type = input("Enter the Grade Type (hw, proj, test, Partic, other): ")
            score = int(input("Enter the Score (out of 100): "))
            add_grade(cursor, connection, crn, student_id, grade_name, grade_type, score)
        elif choice == '3':
            break
        else:
            print("Invalid choice.")

def main():
    print("Welcome to the School Grading System")
    connection = get_connection()
    if not connection:
        return

    cursor = connection.cursor()

    while True:
        print("\n--- Main Menu ---")
        print("Are you a Teacher or a Student?")
        print("1. Student")
        print("2. Teacher")
        print("3. Exit")
        role = input("Select your role: ")

        if role == '1':
            student_menu(cursor, connection)
        elif role == '2':
            teacher_menu(cursor, connection)
        elif role == '3':
            print("Exiting program.")
            break
        else:
            print("Invalid choice. Please enter 1, 2, or 3.")

    cursor.close()
    connection.close()

if __name__ == "__main__":
    main()
